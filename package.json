{
  "name": "caret",
  "type": "module",
  "version": "0.1.1",
  "private": true,
  "description": "Chrome extension to save and invoke reusable prompts via fuzzy dropdown",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write --ignore-path .gitignore . && shfmt --write --indent 2 scripts/",
    "check:format": "prettier --check --ignore-path .gitignore . && shfmt --diff --indent 2 scripts/",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "check:spell": "cspell '**' --no-progress --color --show-context",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "check": "./scripts/verify.sh",
    "check:full": "./scripts/verify.sh && bun run test:e2e",
    "clean": "./scripts/clean.sh",
    "update": "./scripts/update.sh",
    "check:shell": "find scripts -name '*.sh' -exec shellcheck --severity=warning {} +",
    "snapshot": "./scripts/snapshot.sh",
    "release": "./scripts/release.sh",
    "verify": "./scripts/verify.sh",
    "screenshot": "bun run build && node --experimental-strip-types e2e/screenshot.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@crxjs/vite-plugin": "^2.3.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cspell": "^9.7.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.0.18"
  },
  "author": "Eric Le"
}
